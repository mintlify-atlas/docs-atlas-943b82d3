  "keyFeatures": [
    "Self-improving learning loop with autonomous skill creation from experience",
    "Multi-platform messaging gateway (Telegram, Discord, Slack, WhatsApp, Signal, Email)",
    "40+ built-in tools including terminal, file ops, web search, browser automation, and code execution",
    "Support for 200+ LLM models via OpenRouter, Anthropic, OpenAI, and custom endpoints",
    "Six terminal backends: local, Docker, SSH, Daytona, Singularity, and Modal (serverless)",
    "FTS5 full-text session search with LLM summarization for cross-session recall",
    "MCP (Model Context Protocol) server integration for extended capabilities",
    "Built-in cron scheduler for scheduled automations delivered to any platform",
    "Subagent delegation for parallel workstreams",
    "Honcho dialectic user modeling for persistent user profiles"
  ],
  "publicApiSurface": [
    "hermes — start interactive CLI conversation",
    "hermes model — choose LLM provider and model",
    "hermes tools — configure enabled tools",
    "hermes config set — set individual config values",
    "hermes gateway — start messaging gateway",
    "hermes setup — run full setup wizard",
    "hermes claw migrate — migrate from OpenClaw",
    "hermes update — update to latest version",
    "hermes doctor — diagnose issues",
    "AIAgent.chat(message: str) -> str",
    "AIAgent.run_conversation(user_message, system_message, conversation_history, task_id) -> dict",
    "/new, /reset — start fresh session",
    "/model [provider:model] — change model mid-session",
    "/skills — search, install, manage skills",
    "/cron — manage scheduled tasks",
    "/compress — compress conversation context",
    "/background <prompt> — run prompt in background",
    "registry.register(name, toolset, schema, handler, check_fn) — register a new tool"
  ]
